# ── App ────────────────────────────────────────────────────────

APP_ENV=development
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── JWT ────────────────────────────────────────────────────────

JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────

POSTGRES_USER=raguser
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=ragdb

# Local Development:

# DATABASE_URL=postgresql+asyncpg://raguser:your-postgres-password@localhost:5432/ragdb

# Docker:

DATABASE_URL=postgresql+asyncpg://raguser:your-postgres-password@postgres:5432/ragdb

# ── Redis ──────────────────────────────────────────────────────

REDIS_PASSWORD=your-redis-password

# Local Development:

# REDIS_URL=redis://:your-redis-password@localhost:6379/0

# Docker:

REDIS_URL=redis://:your-redis-password@redis:6379/0

# ── Qdrant ─────────────────────────────────────────────────────

QDRANT_API_KEY=your-qdrant-api-key

# Local Development:

# QDRANT_URL=http://localhost:6333

# Docker:

QDRANT_URL=http://qdrant:6333

# ── Elasticsearch ──────────────────────────────────────────────

ELASTIC_USER=elastic
ELASTIC_PASSWORD=your-elastic-password

# Local Development:

# ELASTIC_URL=http://localhost:9200

# Docker:

ELASTIC_URL=http://elasticsearch:9200

# ── LLM / OpenRouter ───────────────────────────────────────────

OPENROUTER_API_KEY=your-openrouter-api-key

# Main generation model

LLM_MODEL=google/gemma-4-31b-it:free

# Critic / grounding verification model

CRITIC_LLM_MODEL=openai/gpt-oss-120b:free

LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── Reranker ───────────────────────────────────────────────────

LOCAL_RERANKER=true

# COHERE_API_KEY=your-cohere-api-key

# ── Embeddings ────────────────────────────────────────────────

EMBEDDING_MODEL_VERSION=BAAI/bge-m3
LOCAL_EMBEDDING=true

# JINA_API_KEY=your-jina-api-key

# ── Rate Limiting ─────────────────────────────────────────────

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
