# ── App ────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Postgres ───────────────────────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ragdb
DATABASE_URL=postgresql+asyncpg://raguser:CHANGE_ME@postgres:5432/ragdb

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=CHANGE_ME

# ── Elasticsearch ──────────────────────────────────────────────
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_PASSWORD=CHANGE_ME

# ── LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME

# ── Reranker (choose one) ──────────────────────────────────────
COHERE_API_KEY=CHANGE_ME
# LOCAL_RERANKER=true  # uncomment to use BGE-Reranker-Large

# ── Embedding ──────────────────────────────────────────────────
# LOCAL_EMBEDDING=true  # BGE-M3 local
# JINA_API_KEY=CHANGE_ME  # Jina AI API fallback

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60