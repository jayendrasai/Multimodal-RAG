*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.gguf
# BGE-M3 / BGE-Reranker local cache
.cache/huggingface/
.cache/torch/
huggingface/

# ── Vector Store & Search Data ────────────────────────────────
# Local Qdrant / Elasticsearch data volumes (managed by Docker)
qdrant_storage/
elasticsearch_data/
postgres_data/

# ── Uploaded Documents ─────────────────────────────────────────
# User-uploaded files must never be committed — highly sensitive
uploads/
tmp/
temp/
*.pdf
*.docx
*.eml
*.msg

# ── Build Artifacts ────────────────────────────────────────────
*.pyc
*.pyo
.build/
__pypackages__/

